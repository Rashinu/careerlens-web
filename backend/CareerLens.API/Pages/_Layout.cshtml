<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CareerLens — @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: -0.5px; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        .badge-status-Uploaded { background-color: #6c757d; }
        .badge-status-TextExtracted { background-color: #0d6efd; }
        .badge-status-Analyzed { background-color: #198754; }
        .badge-status-Failed { background-color: #dc3545; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🔍 CareerLens</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/Demo">Demo</a>
                <a class="nav-link" href="/swagger" target="_blank">Swagger</a>
                <a class="nav-link" href="/hangfire" target="_blank">Hangfire</a>
            </div>
        </div>
    </nav>
    <div class="container pb-5">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
