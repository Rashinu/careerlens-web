@page
@model DemoModel
@{
    ViewData["Title"] = "Demo";
}

<h2 class="fw-bold mb-4">CareerLens Demo</h2>

<div class="row g-4">

    @* Adım 1: Kayıt / Giriş *@
    <div class="col-12">
        <div class="card p-4">
            <h5 class="fw-bold mb-3">1. Kayıt Ol / Giriş Yap</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <input type="email" id="email" class="form-control" placeholder="Email" value="demo@careerlens.com" />
                </div>
                <div class="col-md-4">
                    <input type="password" id="password" class="form-control" placeholder="Şifre" value="Demo1234!" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-dark w-100" onclick="register()">Kayıt Ol</button>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-dark w-100" onclick="login()">Giriş</button>
                </div>
            </div>
            <div id="auth-result" class="mt-3 small text-muted"></div>
        </div>
    </div>

    @* Adım 2: CV Yükle *@
    <div class="col-12">
        <div class="card p-4">
            <h5 class="fw-bold mb-3">2. CV Yükle</h5>
            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <input type="file" id="cv-file" class="form-control" accept=".pdf,.docx" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-dark w-100" onclick="uploadCv()">Yükle</button>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-secondary w-100" onclick="listCvs()">CV Listesini Gör</button>
                </div>
            </div>
            <div id="cv-result" class="mt-3 small"></div>
        </div>
    </div>

    @* Adım 3: Maaş Benchmark *@
    <div class="col-12">
        <div class="card p-4">
            <h5 class="fw-bold mb-3">3. Maaş Karşılaştırma</h5>
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <input type="text" id="bm-position" class="form-control" placeholder="Pozisyon" value=".NET Developer" />
                </div>
                <div class="col-md-3">
                    <input type="text" id="bm-city" class="form-control" placeholder="Şehir" value="İstanbul" />
                </div>
                <div class="col-md-2">
                    <input type="number" id="bm-years" class="form-control" placeholder="Yıl" value="3" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-dark w-100" onclick="getBenchmark()">Sorgula</button>
                </div>
            </div>
            <div id="benchmark-result" class="mt-3"></div>
        </div>
    </div>

    @* Adım 4: Roadmap *@
    <div class="col-12">
        <div class="card p-4">
            <h5 class="fw-bold mb-3">4. Kariyer Roadmap Al</h5>
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <input type="text" id="cv-id" class="form-control" placeholder="CV Analysis ID (listeden al)" />
                </div>
                <div class="col-md-4">
                    <input type="text" id="target-position" class="form-control" placeholder="Hedef Pozisyon" value="Senior .NET Developer" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-dark w-100" onclick="createRoadmap()">Roadmap Oluştur</button>
                </div>
            </div>
            <div id="roadmap-result" class="mt-3 small"></div>
        </div>
    </div>

</div>

<script>
    const API = '';
    let token = localStorage.getItem('cl_token') || '';

    function setToken(t) { token = t; localStorage.setItem('cl_token', t); }

    function headers() {
        return { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token };
    }

    function showResult(el, data, isError) {
        document.getElementById(el).innerHTML =
            `<pre class="p-3 rounded ${isError ? 'bg-danger-subtle' : 'bg-light'}">${JSON.stringify(data, null, 2)}</pre>`;
    }

    async function register() {
        const r = await fetch('/api/auth/register', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: val('email'), password: val('password') })
        });
        const d = await r.json();
        if (d.success) { setToken(d.data.accessToken); showResult('auth-result', { mesaj: 'Kayıt başarılı, token alındı', expires: d.data.expiresAt }, false); }
        else showResult('auth-result', d, true);
    }

    async function login() {
        const r = await fetch('/api/auth/login', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: val('email'), password: val('password') })
        });
        const d = await r.json();
        if (d.success) { setToken(d.data.accessToken); showResult('auth-result', { mesaj: 'Giriş başarılı', expires: d.data.expiresAt }, false); }
        else showResult('auth-result', d, true);
    }

    async function uploadCv() {
        const file = document.getElementById('cv-file').files[0];
        if (!file) { alert('Önce dosya seçin'); return; }
        const fd = new FormData();
        fd.append('file', file);
        const r = await fetch('/api/cv/upload', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token }, body: fd });
        const d = await r.json();
        if (d.success) { document.getElementById('cv-id').value = d.data.id; }
        showResult('cv-result', d, !d.success);
    }

    async function listCvs() {
        const r = await fetch('/api/cv/list', { headers: headers() });
        const d = await r.json();
        showResult('cv-result', d, !d.success);
        if (d.success && d.data.length > 0) document.getElementById('cv-id').value = d.data[0].id;
    }

    async function getBenchmark() {
        const pos = val('bm-position'), city = val('bm-city'), years = val('bm-years');
        const r = await fetch(`/api/salary/benchmark?position=${encodeURIComponent(pos)}&city=${encodeURIComponent(city)}&years=${years}`);
        const d = await r.json();
        if (d.success) {
            const b = d.data;
            document.getElementById('benchmark-result').innerHTML = `
                <div class="row g-3 mt-1">
                    <div class="col-md-3"><div class="card p-3 text-center"><small class="text-muted">P25</small><div class="fs-4 fw-bold">₺${b.p25.toLocaleString()}</div></div></div>
                    <div class="col-md-3"><div class="card p-3 text-center border-dark"><small class="text-muted">Medyan (P50)</small><div class="fs-4 fw-bold">₺${b.p50.toLocaleString()}</div></div></div>
                    <div class="col-md-3"><div class="card p-3 text-center"><small class="text-muted">P75</small><div class="fs-4 fw-bold">₺${b.p75.toLocaleString()}</div></div></div>
                    <div class="col-md-3"><div class="card p-3 text-center bg-light"><small class="text-muted">Örneklem</small><div class="fs-4 fw-bold">${b.sampleCount}</div></div></div>
                </div>`;
        } else showResult('benchmark-result', d, true);
    }

    async function createRoadmap() {
        const id = val('cv-id');
        if (!id) { alert('CV ID gerekli (CV listesinden alın)'); return; }
        const r = await fetch(`/api/cv/${id}/roadmap`, {
            method: 'POST', headers: headers(),
            body: JSON.stringify({ targetPosition: val('target-position') })
        });
        const d = await r.json();
        showResult('roadmap-result', d, !d.success);
    }

    function val(id) { return document.getElementById(id).value; }
</script>
